{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "2.1.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "icons": {
    "128": "assets/icon.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/materials.svg",
        "css/overlay.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}